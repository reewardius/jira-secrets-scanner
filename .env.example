# ============================================================
# Jira Secret Scanner — configuration
# ============================================================

# --- Required parameters ---

# Atlassian account email
JIRA_EMAIL=user@company.com

# API token (generate at: https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_TOKEN=ATATT3xFfGF0your_token_here_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Jira instance URL (no trailing slash)
JIRA_URL=https://yourcompany.atlassian.net


# --- AWS SES (optional, only needed for email notifications) ---

# AWS credentials (can be omitted if using IAM role / instance profile)
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_DEFAULT_REGION=us-east-1
